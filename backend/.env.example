PORT=3001
NODE_ENV=development

# Supabase (get from supabase.com → project settings → API)
# This same project also powers "Sign in with Google" for staff —
# enable the Google provider under Authentication → Providers in Supabase.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Twilio (optional — leave blank for demo/console mode)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+15550000000
SMS_ENABLED=false

# App config
FRONTEND_URL=http://localhost:5173
STAFF_PIN=1234
DEFAULT_CLINIC_ID=a0000000-0000-0000-0000-000000000001
BASE_SERVICE_MINUTES=8
REMINDER_THRESHOLD=3
